{
  "name": "sistema-vacaciones-rh",
  "version": "1.0.0",
  "description": "Sistema local para gestión de vacaciones del personal de RH",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.empresa.sistema-vacaciones-rh",
    "productName": "Sistema RH",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*",
      "database/**/*",
      "!backend/node_modules/**/*",
      "!**/node_modules/.cache/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "frontend/public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sistema RH"
    }
  }
}